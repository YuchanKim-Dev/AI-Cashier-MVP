OPENAI_API_KEY=                       # platform.openai.com에서 발급, 결제 등록 필요
OPENAI_REALTIME_MODEL=gpt-realtime-2  # 기본값 유지 권장
OPENAI_REALTIME_VOICE=                # 사용 가능 voice: alloy, echo, shimmer, marin, cedar 등 확인 후 입력

DATABASE_URL=                         # postgresql://user:pass@localhost:5432/voicecashier (3단계 전까지 비워둬도 됨)

HF_TOKEN=                             # (선택) SpeechBrain 모델 다운로드용. 공개 모델이면 불필요

# 화자인증 파라미터 (4단계에서 조정)
SPEAKER_VERIFY_INTERVAL=3             # 지속 검증 주기(초)
SPEAKER_VERIFY_THRESHOLD=0.75         # 코사인 유사도 임계값 (0~1, 높을수록 엄격)
SPEAKER_VERIFY_MAX_FAIL=3             # 연속 불일치 허용 횟수 (초과 시 세션 종료)
